local UIS = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local Players = game:GetService("Players")

local LP = Players.LocalPlayer

local function getChar()
	return LP.Character or LP.CharacterAdded:Wait()
end

local flyActive = false
local bv
local moveY = 0

local isPC = UIS.KeyboardEnabled and UIS.MouseEnabled

local screenGui = Instance.new("ScreenGui")
screenGui.Name = "FlyUI"
screenGui.ResetOnSpawn = false
screenGui.Parent = game.CoreGui

local function makeBtn(text, pos)
	local b = Instance.new("TextButton")
	b.Size = UDim2.new(0, 60, 0, 60)
	b.Position = pos
	b.Text = text
	b.TextScaled = true
	b.BackgroundTransparency = 0.3
	b.Parent = screenGui
	return b
end

local function makeText(text, pos)
	local t = Instance.new("TextLabel")
	t.Size = UDim2.new(0, 140, 0, 60)
	t.Position = pos
	t.BackgroundTransparency = 1
	t.Text = text
	t.TextScaled = true
	t.TextColor3 = Color3.new(1,1,1)
	t.TextStrokeTransparency = 0
	t.Font = Enum.Font.SourceSansBold
	t.Parent = screenGui
	return t
end

local toggleBtn
local upBtn
local downBtn
local pcText

if not isPC then
	toggleBtn = makeBtn(
		"FLY",
		UDim2.new(1,-70,0,20)
	)

	upBtn = makeBtn(
		"UP",
		UDim2.new(1,-70,0.6,-60)
	)

	downBtn = makeBtn(
		"DOWN",
		UDim2.new(1,-70,0.75,-60)
	)

	upBtn.Visible = false
	downBtn.Visible = false
else
	pcText = makeText(
		"UP\n(Space) | DOWN\n(Left Shift)\nTOGGLE (P)",
		UDim2.new(1,-170,0,20)
	)

	pcText.Visible = false
end

local function getSpeed()
	local char = getChar()
	local hum = char:FindFirstChildOfClass("Humanoid")
	return hum and hum.WalkSpeed or 16
end

local function startFly()
	local char = getChar()
	local hrp = char:WaitForChild("HumanoidRootPart")

	if bv then
		bv:Destroy()
	end

	bv = Instance.new("BodyVelocity")
	bv.MaxForce = Vector3.new(1e5,1e5,1e5)
	bv.Velocity = Vector3.zero
	bv.Parent = hrp

	RunService:BindToRenderStep("FlyMove", 0, function()
		if not flyActive then return end

		local char = getChar()
		local hum = char:FindFirstChildOfClass("Humanoid")
		if not hum then return end

		local flySpeed = math.clamp(hum.WalkSpeed, 50, math.huge)
		local moveDir = hum.MoveDirection
		local velocity = moveDir * flySpeed

		if bv then
			bv.Velocity = Vector3.new(
				velocity.X,
				moveY,
				velocity.Z
			)
		end
	end)
end

local function stopFly()
	RunService:UnbindFromRenderStep("FlyMove")

	if bv then
		bv:Destroy()
		bv = nil
	end

	moveY = 0
end

local function toggleFly()
	flyActive = not flyActive

	if flyActive then
		startFly()

		if upBtn then
			upBtn.Visible = true
			downBtn.Visible = true
		end

		if pcText then
			pcText.Visible = true
		end
	else
		stopFly()

		if upBtn then
			upBtn.Visible = false
			downBtn.Visible = false
		end

		if pcText then
			pcText.Visible = false
		end
	end
end

if toggleBtn then
	toggleBtn.MouseButton1Click:Connect(toggleFly)

	upBtn.MouseButton1Down:Connect(function()
		moveY = getSpeed()
	end)

	upBtn.MouseButton1Up:Connect(function()
		moveY = 0
	end)

	downBtn.MouseButton1Down:Connect(function()
		moveY = -getSpeed()
	end)

	downBtn.MouseButton1Up:Connect(function()
		moveY = 0
	end)
end

UIS.InputBegan:Connect(function(input)
	if input.KeyCode == Enum.KeyCode.P then
		toggleFly()
	end

	if not flyActive then return end

	if input.KeyCode == Enum.KeyCode.Space then
		moveY = getSpeed()
	end

	if input.KeyCode == Enum.KeyCode.LeftShift then
		moveY = -getSpeed()
	end
end)

UIS.InputEnded:Connect(function(input)
	if input.KeyCode == Enum.KeyCode.Space
	or input.KeyCode == Enum.KeyCode.LeftShift then
		moveY = 0
	end
end)
